{
  "expo": {
    "name": "AWSnoozr",
    "slug": "awsnoozr-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#4299e1"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.awsnoozr.mobile",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Use Face ID to securely login to AWSnoozr",
        "NSCameraUsageDescription": "Camera access for QR code scanning (future feature)"
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#4299e1"
      },
      "package": "com.awsnoozr.mobile",
      "permissions": [
        "android.permission.VIBRATE",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#4299e1"
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow AWSnoozr to use Face ID for secure authentication"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "your-project-id-here"
      }
    }
  }
}
